# Cognee MCP server environment template.
# Copy to ~/.claude/cognee-mcp/cognee-mcp/.env after cloning the cognee MCP server.
#
# CHANGE THE PASSWORDS before using. The defaults match docker-compose.yml in
# this directory; if you change them there, change them here too.
#
# Also: the env block in your ~/.claude/settings.json `mcpServers.cognee.env`
# OVERRIDES this file. Keep them in sync, or pick one as source of truth.

# === LLM (entity extraction during cognify) ===
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:32b-16k
LLM_ENDPOINT=http://localhost:11434/v1
LLM_API_KEY=ollama_no_key_needed

# === Embeddings ===
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text:latest
EMBEDDING_ENDPOINT=http://localhost:11434/api/embed
EMBEDDING_DIMENSIONS=768

# === Graph database (Neo4j) ===
GRAPH_DATABASE_PROVIDER=neo4j
GRAPH_DATABASE_URL=bolt://localhost:7687
GRAPH_DATABASE_USERNAME=neo4j
GRAPH_DATABASE_PASSWORD=pleaseletmein

# === Relational database (Postgres for pipeline state) ===
DB_PROVIDER=postgres
DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=cognee_db
DB_USERNAME=cognee
DB_PASSWORD=cognee_local_dev

# === Vector database (LanceDB, file-based — no server needed) ===
VECTOR_DB_PROVIDER=lancedb
VECTOR_DB_URL=~/.claude/cognee-data/lancedb

# === Cognee data directory ===
COGNEE_USER_FILES_PATH=~/.claude/cognee-data

# === Optional tuning ===
# LITELLM_LOG=ERROR             # silence verbose litellm logs
# COGNEE_LOG_LEVEL=INFO

# === Cloud alternatives (uncomment and configure if not using local Ollama) ===

# --- Anthropic ---
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-haiku-4-5
# LLM_API_KEY=sk-ant-...

# --- Gemini ---
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.5-flash
# LLM_API_KEY=...

